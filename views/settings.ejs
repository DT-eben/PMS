<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PMS - Settings</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif;}
body{display:flex;background:#f1f5f9;min-height:100vh;}

/* SIDEBAR */
.sidebar{width:220px;background:#1e293b;color:white;padding:20px;flex-shrink:0;}
.sidebar h2{margin-bottom:20px;font-size:18px;}
.sidebar a{display:block;color:white;text-decoration:none;padding:12px;border-radius:8px;margin-bottom:8px;font-size:14px;transition:0.2s;}
.sidebar a:hover,.sidebar .active{background:#3b82f6;}

/* MAIN */
.main{flex:1;padding:30px;overflow-y:auto;}

/* TOPBAR */
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;}
.topbar h2{font-size:20px;font-weight:600;color:#0f172a;}
.topbar span{font-size:14px;color:#64748b;font-weight:500;}

/* FLASH */
.flash{padding:12px 18px;border-radius:10px;margin-bottom:20px;font-size:14px;font-weight:500;}
.flash-success{background:#dcfce7;color:#166534;border-left:4px solid #22c55e;}
.flash-error{background:#fee2e2;color:#991b1b;border-left:4px solid #ef4444;}

/* LAYOUT GRID */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.full{grid-column:1/-1;}

/* SECTION CARD */
.section-card{background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.05);}
.section-card h3{font-size:14px;font-weight:600;color:#0f172a;margin-bottom:4px;display:flex;align-items:center;gap:8px;}
.section-card p.sub{font-size:13px;color:#94a3b8;margin-bottom:20px;}
.divider{height:1px;background:#f1f5f9;margin-bottom:20px;}

/* PROFILE DISPLAY */
.profile-row{display:flex;align-items:center;gap:16px;margin-bottom:20px;}
.avatar{width:60px;height:60px;border-radius:50%;background:#2563eb;color:white;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;flex-shrink:0;}
.profile-row .info h4{font-size:15px;font-weight:600;color:#0f172a;margin-bottom:2px;}
.profile-row .info p{font-size:13px;color:#64748b;text-transform:capitalize;}

/* STAT PILLS */
.stat-row{display:flex;gap:10px;flex-wrap:wrap;}
.stat-pill{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 16px;font-size:13px;color:#475569;display:flex;align-items:center;gap:7px;font-weight:500;}
.stat-pill i{color:#3b82f6;font-size:15px;}

/* FORM */
.form-group{margin-bottom:14px;}
.form-group label{font-size:11px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:5px;}
.form-group input,.form-group select{width:100%;padding:10px 13px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:14px;color:#1e293b;background:white;outline:none;transition:0.2s;font-family:'Inter',sans-serif;}
.form-group input:focus,.form-group select:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,0.1);}
.form-two{display:grid;grid-template-columns:1fr 1fr;gap:14px;}

/* BUTTONS */
.btn-primary{width:100%;padding:11px;border:none;background:#1e293b;color:white;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:0.2s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:4px;}
.btn-primary:hover{background:#334155;}
.btn-danger{width:100%;padding:11px;border:none;background:#fee2e2;color:#991b1b;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:0.2s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-danger:hover{background:#fecaca;color:#7f1d1d;}
.btn-outline{width:100%;padding:11px;border:1.5px solid #e2e8f0;background:white;color:#475569;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:0.2s;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;}
.btn-outline:hover{background:#f8fafc;color:#1e293b;}

/* INFO ROWS */
.info-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid #f8fafc;font-size:14px;}
.info-row:last-child{border-bottom:none;}
.info-row .label{color:#94a3b8;font-size:13px;}
.info-row .value{color:#1e293b;font-weight:500;font-size:13px;}

/* TOGGLE SECTION */
.toggle-header{display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 0;}
.toggle-header:hover .toggle-label{color:#3b82f6;}
.toggle-label{font-size:14px;font-weight:500;color:#1e293b;display:flex;align-items:center;gap:8px;}
.toggle-body{margin-top:18px;}
.chevron{font-size:12px;color:#94a3b8;transition:transform 0.2s;}
.chevron.open{transform:rotate(180deg);}

/* DANGER ZONE */
.danger-card{background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.05);border-left:4px solid #ef4444;}
.danger-card h3{font-size:14px;font-weight:600;color:#991b1b;margin-bottom:4px;display:flex;align-items:center;gap:8px;}
.danger-card p.sub{font-size:13px;color:#94a3b8;margin-bottom:18px;}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <h2>PMS</h2>
  <a href="/dashboard">Dashboard</a>

  <!-- Patients: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/records">Patients</a>
  <% } %>

  <!-- Visits: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/visits">Visits</a>
  <% } %>

  <!-- Doctors list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/doctors">Doctors</a>
  <% } %>

  <!-- Queue: doctor only -->
  <% if (role === 'doctor') { %>
    <a href="/queue">Queue</a>
  <% } %>

  <!-- Nurses list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/nurses">Nurses</a>
  <% } %>

  <!-- Admitted: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/admitted">Admitted</a>
  <% } %>

  <!-- Lab: lab only -->
  <% if (role === 'lab') { %>
    <a href="/lab">Labs</a>
  <% } %>

  <a href="/settings" class="active">Settings</a>
</div>

<!-- MAIN -->
<div class="main">

  <div class="topbar">
    <h2>Settings</h2>
    <span><%= name %></span>
  </div>

  <!-- FLASH -->
  <% if (success && success.length > 0) { %>
    <div class="flash flash-success"><i class="bi bi-check-circle"></i> <%= success %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
  <% } %>

  <div class="settings-grid">

    <!-- ── MY PROFILE ── -->
    <div class="section-card">
      <h3><i class="bi bi-person-circle"></i> My Profile</h3>
      <p class="sub">Your account details on this system</p>
      <div class="divider"></div>

      <div class="profile-row">
        <div class="avatar"><%= name ? name.charAt(0).toUpperCase() : 'U' %></div>
        <div class="info">
          <h4><%= name %></h4>
          <p><%= role || 'Staff' %></p>
        </div>
      </div>

      <div class="info-row">
        <span class="label">Role</span>
        <span class="value" style="text-transform:capitalize"><%= role || '—' %></span>
      </div>
      <div class="info-row">
        <span class="label">Staff ID</span>
        <span class="value"><%= staffID || '—' %></span>
      </div>
      <div class="info-row">
        <span class="label">Department</span>
        <span class="value"><%= department || '—' %></span>
      </div>
      <div class="info-row">
        <span class="label">Email</span>
        <span class="value"><%= email || '—' %></span>
      </div>
    </div>

    <!-- ── CHANGE PASSWORD ── -->
    <div class="section-card">
      <h3><i class="bi bi-shield-lock"></i> Security</h3>
      <p class="sub">Update your password regularly to stay secure</p>
      <div class="divider"></div>
      <form method="POST" action="/change-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label>Current Password</label>
          <input type="password" name="currentPassword" required placeholder="Enter current password">
        </div>

        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="newPassword" required minlength="6" placeholder="At least 6 characters">
        </div>

        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirmPassword" required placeholder="Repeat new password">
        </div>

        <button type="submit" class="btn-primary">
          <i class="bi bi-check-lg"></i> Update Password
        </button>
      </form>
    </div>

    <!-- ── ADD STAFF — admin only ── -->
    <% if (role === 'admin') { %>
    <div class="section-card full">

      <div class="toggle-header" onclick="toggleStaff()">
        <h3 class="toggle-label"><i class="bi bi-person-plus"></i> Add New Staff</h3>
        <i class="bi bi-chevron-down chevron" id="staffChevron"></i>
      </div>

      <div id="addStaffForm" class="toggle-body" style="display:none;">
        <div class="divider" style="margin-top:16px;"></div>
        <p class="sub" style="margin-bottom:18px;">Create a new staff account. Login credentials will be emailed automatically.</p>

        <form method="POST" action="/addstaff">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-two">
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="name" required minlength="3" placeholder="e.g. John Mensah">
            </div>

            <div class="form-group">
              <label>Email</label>
              <input type="email" name="email" required placeholder="e.g. john@hospital.com">
            </div>

            <div class="form-group">
              <label>Phone</label>
              <input type="tel" name="phone" required pattern="^\+?[0-9]{10,15}$" placeholder="e.g. 0241234567">
            </div>

            <div class="form-group">
              <label>Date of Birth</label>
              <input type="date" name="dob" required>
            </div>

            <div class="form-group">
              <label>Gender</label>
              <select name="gender" required>
                <option value="">Select</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label>Role</label>
              <select name="role" required>
                <option value="">Select Role</option>
                <option value="doctor">Doctor</option>
                <option value="nurse">Nurse</option>
                <option value="lab">Lab</option>
                <option value="admin">Admin</option>
              </select>
            </div>

            <div class="form-group">
              <label>Department</label>
              <input type="text" name="department" required minlength="2" placeholder="e.g. Emergency">
            </div>

            <div class="form-group">
              <label>Emergency Contact</label>
              <input type="tel" name="emergencyContact" required pattern="^\+?[0-9]{10,15}$" placeholder="e.g. 0249876543">
            </div>

            <div class="form-group full">
              <label>Address</label>
              <input type="text" name="address" required minlength="5" placeholder="e.g. Accra, Ghana">
            </div>
          </div>

          <button type="submit" class="btn-primary" style="max-width:200px;">
            <i class="bi bi-person-check"></i> Create Staff
          </button>
        </form>
      </div>
    </div>
    <% } %>

    <!-- ── DANGER ZONE ── -->
    <div class="danger-card full">
      <h3><i class="bi bi-exclamation-triangle"></i> Danger Zone</h3>
      <p class="sub">These actions affect your session. End duty will log you out.</p>

      <div style="display:flex;gap:14px;flex-wrap:wrap;">

        <form method="POST" action="/logout" style="flex:1;min-width:180px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-outline">
            <i class="bi bi-box-arrow-right"></i> Logout
          </button>
        </form>

        <!-- End Duty button: doctors only -->
        <% if (role === 'doctor') { %>
        <form method="POST" action="/doctor/duty/end" style="flex:1;min-width:180px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-danger">
            <i class="bi bi-stop-circle"></i> End Duty & Logout
          </button>
        </form>
        <% } %>

      </div>
    </div>

  </div>
</div>

<script>
function toggleStaff() {
  const form = document.getElementById("addStaffForm");
  const chevron = document.getElementById("staffChevron");
  const isOpen = form.style.display !== "none";
  form.style.display = isOpen ? "none" : "block";
  chevron.classList.toggle("open", !isOpen);
}

// Auto open add staff form if there was an error submitting it
<% if (role === 'admin' && error && error.length > 0) { %>
  toggleStaff();
<% } %>


setTimeout(() => {
  document.querySelectorAll('.flash').forEach(el => {
    el.style.transition = '0.4s';
    el.style.opacity = '0';

    setTimeout(() => {
      el.remove();
    }, 400);
  });
}, 4000);

</script>

</body>
</html>