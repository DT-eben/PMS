<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>PMS - Patients</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  display: flex;
  height: 100vh;
  background: #f4f6f9;
}

.sidebar {
  width: 220px;
  background: #1e293b;
  color: #fff;
  padding: 20px;
}

.sidebar h2 {
  margin-bottom: 20px;
}

.sidebar a {
  display: block;
  padding: 12px;
  margin-bottom: 10px;
  color: white;
  text-decoration: none;
  border-radius: 8px;
}

.sidebar a:hover,
.sidebar .active {
  background: #3b82f6;
}

.main {
  flex: 1;
  overflow-y: auto;
  padding: 40px 30px 30px 30px;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  margin-bottom: 30px;
}

.search-box {
  display: flex;
  align-items: center;
  background: white;
  padding: 8px 12px;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.08);
  width: 320px;
}

.search-box input {
  border: none;
  outline: none;
  width: 100%;
  margin-left: 8px;
}

/* SAME CARD STYLE */
.staff-card {
  transition: 0.2s;
  cursor: pointer;
  border: none;
  border-left: 4px solid #3b82f6;
  background-color: #ffffff;
  position: relative;
}

.staff-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
}

.card-link-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.add-btn {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  background: #1e293b;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  text-decoration: none;
  box-shadow: 0 6px 15px rgba(0,0,0,0.2);
}

.add-btn:hover {
  background: #334155;
  transform: scale(1.1);
}
</style>
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
  <h2>PMS</h2>
  <a href="/dashboard">Dashboard</a>

  <!-- Patients: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/records" class="active">Patients</a>
  <% } %>

  <!-- Visits: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/visits">Visits</a>
  <% } %>

  <!-- Doctors list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/doctors">Doctors</a>
  <% } %>

  <!-- Queue: doctor only -->
  <% if (role === 'doctor') { %>
    <a href="/queue">Queue</a>
  <% } %>

  <!-- Nurses list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/nurses">Nurses</a>
  <% } %>

  <!-- Admitted: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/admitted">Admitted</a>
  <% } %>

  <!-- Lab: lab only -->
  <% if (role === 'lab') { %>
    <a href="/lab">Labs</a>
  <% } %>

  <a href="/settings" >Settings</a>
</div>

<!-- Main -->
<div class="main">

  <!-- Topbar -->
  <div class="topbar">
    <h2>Patients</h2>

    <div class="search-box">
      <i class="bi bi-search"></i>
      <input type="text" id="searchInput" placeholder="Search patients..." onkeyup="searchPatients()">
    </div>

      <span style="font-size:14px;color:#64748b;font-weight:500;"><%= name %></span>
  </div>

  <!-- PATIENTS -->
  <div id="patientSection">

    <div class="container-fluid">
      <div class="row g-4" id="patientGrid">

        <% if (patients.length === 0) { %>
          <p>No patients added yet.</p>
        <% } %>

        <% patients.forEach(patient => { %>
          <div class="col-md-6 col-lg-4 patient-item">

            <div class="card staff-card shadow-sm">
              <a href="/patient/<%= patient._id %>" class="card-link-overlay"></a>

              <div class="card-body">
                <h5 class="card-title"><%= patient.name %></h5>

                <p class="text-muted mb-1">
                  ID: #<%= patient.patientID %>
                </p>

                <p class="text-muted mb-1">
                  Gender: <%= patient.gender %>
                </p>

                <p class="text-muted mb-1">
                  Contact: <%= patient.number %>
                </p>

                <p class="text-muted">
                  Status:
                  <span class="
                    <%= patient.status === 'Critical' ? 'text-danger' : '' %>
                    <%= patient.status === 'Stable' ? 'text-success' : '' %>
                    <%= patient.status === 'Under observation' ? 'text-warning' : '' %>
                  ">
                    <%= patient.status || "New" %>
                  </span>
                </p>
              </div>

            </div>

          </div>
        <% }) %>

      </div>
    </div>

  </div>

</div>

<!-- Floating Button -->
<a href="/addpa" class="add-btn">
  <i class="bi bi-plus-lg"></i>
</a>

<script>
function searchPatients() {
  let input = document.getElementById("searchInput").value.toLowerCase();
  let items = document.querySelectorAll(".patient-item");

  items.forEach(item => {
    let text = item.innerText.toLowerCase();
    item.style.display = text.includes(input) ? "block" : "none";
  });
}



function searchPatients() {

  // 🔍 get input value
  const input = document
    .getElementById("searchInput")
    .value
    .toLowerCase()
    .trim();

  // 👥 all patient cards
  const patients = document.querySelectorAll(".patient-item");

  // 📌 patient grid
  const patientGrid = document.getElementById("patientGrid");

  // 🔥 track results
  let visibleCount = 0;

  patients.forEach(patient => {

    // 🔍 get all searchable text inside card
    const searchableText = patient.innerText
      .toLowerCase()
      .replace(/\s+/g, " ");

    // ✅ match
    if (searchableText.includes(input)) {

      // show
      patient.style.display = "";

      visibleCount++;

    } else {

      // hide
      patient.style.display = "none";
    }

  });

  // 🔥 REMOVE OLD EMPTY MESSAGE
  const oldMessage = document.getElementById("noResultsMessage");

  if (oldMessage) {
    oldMessage.remove();
  }

  // ❌ IF NOTHING FOUND
  if (visibleCount === 0) {

    const message = document.createElement("div");

    message.id = "noResultsMessage";

    message.innerHTML = `
      <div style="
        width:100%;
        text-align:center;
        padding:40px;
        color:#64748b;
        font-size:16px;
      ">
        <i class="bi bi-search" style="font-size:30px;"></i>
        <p style="margin-top:10px;">
          No patients found
        </p>
      </div>
    `;

    patientGrid.appendChild(message);
  }
}

</script>

</body>
</html>