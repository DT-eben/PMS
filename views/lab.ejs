<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PMS - Laboratory</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Inter',sans-serif;
}

body{
  display:flex;
  background:#f1f5f9;
  min-height:100vh;
  color:#0f172a;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  background:#1e293b;
  color:white;
  padding:20px;
  flex-shrink:0;
}

.sidebar h2{
  margin-bottom:20px;
  font-size:18px;
  font-weight:600;
}

.sidebar a{
  display:block;
  color:white;
  text-decoration:none;
  padding:12px;
  border-radius:8px;
  margin-bottom:8px;
  font-size:14px;
  transition:0.2s;
}

.sidebar a:hover,
.sidebar .active{
  background:#3b82f6;
}

/* MAIN */
.main{
  flex:1;
  padding:30px;
  overflow-y:auto;
}

/* TOPBAR */
.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:28px;
}

.topbar h2{
  font-size:20px;
  font-weight:600;
  color:#0f172a;
}

.topbar span{
  font-size:14px;
  color:#64748b;
  font-weight:500;
}

/* FLASH */
.flash{
  padding:12px 18px;
  border-radius:10px;
  margin-bottom:20px;
  font-size:14px;
  font-weight:500;
  display:flex;
  align-items:center;
  gap:10px;
}

.flash-success{
  background:#dcfce7;
  color:#166534;
  border-left:4px solid #22c55e;
}

.flash-error{
  background:#fee2e2;
  color:#991b1b;
  border-left:4px solid #ef4444;
}

/* STATS */
.stats-row{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  margin-bottom:28px;
}

.stat-card{
  background:white;
  border-radius:14px;
  padding:22px;
  box-shadow:0 2px 8px rgba(0,0,0,0.05);
  display:flex;
  align-items:center;
  gap:16px;
}

.stat-icon{
  width:48px;
  height:48px;
  border-radius:12px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:20px;
  flex-shrink:0;
}

.stat-icon.pending{
  background:#fef3c7;
  color:#92400e;
}

.stat-icon.done{
  background:#dcfce7;
  color:#166534;
}

.stat-icon.total{
  background:#dbeafe;
  color:#1d4ed8;
}

.stat-info p{
  font-size:12px;
  color:#94a3b8;
  font-weight:500;
  margin-bottom:3px;
}

.stat-info h3{
  font-size:24px;
  font-weight:700;
  color:#0f172a;
}

/* SECTION CARD */
.section-card{
  background:white;
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 2px 8px rgba(0,0,0,0.05);
  margin-bottom:24px;
}

.section-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 22px;
  border-bottom:1px solid #f1f5f9;
}

.section-head h3{
  font-size:14px;
  font-weight:600;
  color:#0f172a;
  display:flex;
  align-items:center;
  gap:8px;
}

.count-badge{
  background:#f8fafc;
  color:#475569;
  font-size:12px;
  font-weight:600;
  padding:4px 10px;
  border-radius:20px;
}

/* TABLE */
table{
  width:100%;
  border-collapse:collapse;
}

thead tr{
  background:#fafafa;
  border-bottom:1px solid #f1f5f9;
}

thead th{
  padding:13px 18px;
  font-size:11px;
  font-weight:600;
  color:#94a3b8;
  text-transform:uppercase;
  letter-spacing:0.5px;
  text-align:left;
}

tbody tr{
  border-bottom:1px solid #f8fafc;
  transition:0.2s;
}

tbody tr:last-child{
  border-bottom:none;
}

tbody tr:hover{
  background:#fafafa;
}

tbody td{
  padding:16px 18px;
  font-size:14px;
  color:#1e293b;
  vertical-align:middle;
}

.td-sub{
  font-size:12px;
  color:#94a3b8;
  margin-top:3px;
}

/* QUEUE NUMBER */
.queue-num{
  width:30px;
  height:30px;
  border-radius:50%;
  background:#1e293b;
  color:white;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  font-weight:700;
}

/* BADGES */
.badge{
  padding:5px 11px;
  border-radius:20px;
  font-size:11px;
  font-weight:600;
}

.badge-pending{
  background:#fef3c7;
  color:#92400e;
}

.badge-done{
  background:#dcfce7;
  color:#166534;
}

/* BUTTONS */
.btn-action{
  padding:8px 14px;
  border-radius:8px;
  font-size:13px;
  font-weight:500;
  cursor:pointer;
  transition:0.2s;
  border:none;
  display:inline-flex;
  align-items:center;
  gap:7px;
  text-decoration:none;
}

.btn-upload{
  background:#1e293b;
  color:white;
}

.btn-upload:hover{
  background:#334155;
}

.btn-view{
  background:white;
  color:#475569;
  border:1.5px solid #e2e8f0;
}

.btn-view:hover{
  background:#f8fafc;
  color:#1e293b;
}

/* EMPTY */
.empty-state{
  padding:55px 20px;
  text-align:center;
  color:#94a3b8;
}

.empty-state i{
  font-size:34px;
  margin-bottom:12px;
  display:block;
}

.empty-state p{
  font-size:14px;
}

/* MODAL */
.modal-overlay{
  position:fixed;
  inset:0;
  background:rgba(15,23,42,0.55);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:1000;
  padding:20px;
}

.modal-overlay.open{
  display:flex;
}

.modal{
  background:white;
  border-radius:16px;
  width:100%;
  max-width:540px;
  overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,0.2);
}

.modal-header{
  background:#1e293b;
  color:white;
  padding:20px 24px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.modal-header h3{
  font-size:15px;
  font-weight:600;
  display:flex;
  align-items:center;
  gap:8px;
}

.modal-close{
  background:transparent;
  border:none;
  color:#cbd5e1;
  font-size:22px;
  cursor:pointer;
  line-height:1;
  transition:0.2s;
}

.modal-close:hover{
  color:white;
}

.modal-body{
  padding:24px;
}

.modal-footer{
  padding:18px 24px;
  border-top:1px solid #f1f5f9;
  display:flex;
  justify-content:flex-end;
  gap:12px;
}

/* MODAL FORM */
.m-group{
  margin-bottom:18px;
}

.m-group label{
  display:block;
  font-size:11px;
  font-weight:600;
  color:#64748b;
  text-transform:uppercase;
  letter-spacing:0.5px;
  margin-bottom:6px;
}

.m-group input,
.m-group textarea{
  width:100%;
  padding:11px 13px;
  border:1.5px solid #e2e8f0;
  border-radius:8px;
  font-size:14px;
  color:#0f172a;
  outline:none;
  transition:0.2s;
  font-family:'Inter',sans-serif;
  background:white;
}

.m-group input:focus,
.m-group textarea:focus{
  border-color:#3b82f6;
  box-shadow:0 0 0 3px rgba(59,130,246,0.1);
}

.m-group textarea{
  resize:vertical;
  min-height:110px;
}

.m-info-box{
  background:#f8fafc;
  border-radius:10px;
  padding:15px;
  border:1px solid #e2e8f0;
  margin-bottom:20px;
  font-size:13px;
  color:#475569;
  line-height:1.8;
}

.m-info-box strong{
  color:#0f172a;
}

/* MODAL BUTTONS */
.btn-submit{
  padding:10px 22px;
  background:#1e293b;
  color:white;
  border:none;
  border-radius:8px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  transition:0.2s;
  display:inline-flex;
  align-items:center;
  gap:7px;
}

.btn-submit:hover{
  background:#334155;
}

.btn-cancel{
  padding:10px 18px;
  background:white;
  color:#64748b;
  border:1.5px solid #e2e8f0;
  border-radius:8px;
  font-size:14px;
  font-weight:500;
  cursor:pointer;
  transition:0.2s;
}

.btn-cancel:hover{
  background:#f8fafc;
  color:#1e293b;
}

/* VIEW MODAL */
.result-block{
  background:#f8fafc;
  border-radius:10px;
  padding:18px;
  border:1px solid #e2e8f0;
  font-size:14px;
  color:#1e293b;
  line-height:1.8;
  white-space:pre-wrap;
  margin-bottom:16px;
}

/* RESPONSIVE */
@media(max-width:1000px){

  .stats-row{
    grid-template-columns:1fr;
  }

}

@media(max-width:768px){

  body{
    flex-direction:column;
  }

  .sidebar{
    width:100%;
  }

  .main{
    padding:20px;
  }

  .topbar{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
  }

  .section-card{
    overflow-x:auto;
  }

  table{
    min-width:700px;
  }

}
@media (max-width: 768px){
  .modal-footer{flex-direction:column-reverse;gap:8px;}
  .modal-footer button,.modal-footer .btn-submit,.modal-footer .btn-cancel{width:100%;}

  .section-head{flex-wrap:wrap;gap:8px;}
}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <h2>PMS</h2>
  <a href="/dashboard">Dashboard</a>

  <!-- Patients: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/records">Patients</a>
  <% } %>

  <!-- Visits: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/visits">Visits</a>
  <% } %>

  <!-- Doctors list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/doctors">Doctors</a>
  <% } %>

  <!-- Queue: doctor only -->
  <% if (role === 'doctor') { %>
    <a href="/queue">Queue</a>
  <% } %>

  <!-- Nurses list: admin only -->
  <% if (role === 'admin') { %>
    <a href="/nurses">Nurses</a>
  <% } %>

  <!-- Admitted: nurse, doctor, admin -->
  <% if (role === 'nurse' || role === 'doctor' || role === 'admin') { %>
    <a href="/admitted">Admitted</a>
  <% } %>

  <!-- Lab: lab only -->
  <% if (role === 'lab') { %>
    <a href="/lab" class="active"> Labs</a>
  <% } %>

  <a href="/settings" >Settings</a>
</div>

<!-- MAIN -->
<div class="main">

  <div class="topbar">
    <h2>Laboratory</h2>
    <span><%= name %></span>
  </div>

  <!-- FLASH -->
  <% if (success && success.length > 0) { %>
    <div class="flash flash-success"><i class="bi bi-check-circle"></i> <%= success %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
  <% } %>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon pending"><i class="bi bi-hourglass-split"></i></div>
      <div class="stat-info">
        <p>Pending</p>
        <h3><%= pending.length %></h3>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon done"><i class="bi bi-check-circle"></i></div>
      <div class="stat-info">
        <p>Completed Today</p>
        <h3><%= completed.length %></h3>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon total"><i class="bi bi-flask"></i></div>
      <div class="stat-info">
        <p>Total Today</p>
        <h3><%= pending.length + completed.length %></h3>
      </div>
    </div>
  </div>

  <!-- PENDING QUEUE -->
  <div class="section-card">
    <div class="section-head">
      <h3><i class="bi bi-hourglass-split"></i> Lab Queue <span class="count-badge"><%= pending.length %></span></h3>
    </div>

    <% if (pending.length === 0) { %>
      <div class="empty-state">
        <i class="bi bi-flask"></i>
        <p>No pending lab requests</p>
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Patient</th>
          <th>Tests Required</th>
          <th>Requested By</th>
          <th>Time</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% pending.forEach((visit, index) => { %>
        <tr>
          <td><div class="queue-num"><%= index + 1 %></div></td>
          <td>
            <div style="font-weight:600;"><%= visit.patient.name %></div>
            <div class="td-sub"><%= visit.patient.patientID %></div>
          </td>
          <td><%= visit.tests || '—' %></td>
          <td><%= visit.doctor ? visit.doctor.name : '—' %></td>
          <td>
            <div><%= new Date(visit.createdAt).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'}) %></div>
            <div class="td-sub"><%= new Date(visit.createdAt).toLocaleDateString('en-GB') %></div>
          </td>
          <td>
            <button class="btn-action btn-upload"
              onclick="openUpload(
                '<%= visit._id %>',
                '<%= visit.patient.name %>',
                '<%= visit.tests ? visit.tests.replace(/'/g, "\\'") : "Not specified" %>',
                '<%= visit.doctor ? visit.doctor.name : "Unknown" %>'
              )">
              <i class="bi bi-upload"></i> Upload Results
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- COMPLETED TODAY -->
  <div class="section-card">
    <div class="section-head">
      <h3><i class="bi bi-check-circle"></i> Completed Today <span class="count-badge"><%= completed.length %></span></h3>
    </div>

    <% if (completed.length === 0) { %>
      <div class="empty-state">
        <i class="bi bi-clipboard-check"></i>
        <p>No completed labs yet today</p>
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Patient</th>
          <th>Tests</th>
          <th>Doctor</th>
          <th>Completed At</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% completed.forEach(visit => { %>
        <tr>
          <td>
            <div style="font-weight:600;"><%= visit.patient.name %></div>
            <div class="td-sub"><%= visit.patient.patientID %></div>
          </td>
          <td><%= visit.tests || '—' %></td>
          <td><%= visit.doctor ? visit.doctor.name : '—' %></td>
          <td>
            <%= visit.labCompletedAt
              ? new Date(visit.labCompletedAt).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'})
              : '—' %>
          </td>
          <td><span class="badge badge-done"><i class="bi bi-check-lg"></i> Done</span></td>
          <td>
            <button class="btn-action btn-view"
              onclick="openView(
                '<%= visit.patient.name %>',
                '<%= visit.tests ? visit.tests.replace(/'/g, "\\'") : "—" %>',
                '<%= visit.doctor ? visit.doctor.name : "—" %>',
                '<%= visit.labResults ? visit.labResults.replace(/'/g, "\\'").replace(/\n/g, "\\n") : "No notes uploaded" %>',
                '<%= visit.labResult || "" %>'
              )">
              <i class="bi bi-eye"></i> View
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

</div>

<!-- UPLOAD MODAL -->
<div class="modal-overlay" id="uploadModal">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="bi bi-flask"></i> Upload Lab Results</h3>
      <button class="modal-close" onclick="closeUpload()">✕</button>
    </div>
    <form method="POST" action="/lab/upload" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="visitId" id="upload-visit-id">
      <div class="modal-body">
        <div class="m-info-box">
          <div><strong id="upload-patient"></strong></div>
          <div style="margin-top:4px;">Tests: <strong id="upload-tests"></strong></div>
          <div style="margin-top:2px;">Doctor: <strong id="upload-doctor"></strong></div>
        </div>
        <div class="m-group">
          <label>Results & Notes</label>
          <textarea name="labResults" placeholder="Enter test results, values, observations..." required></textarea>
        </div>
        <div class="m-group">
          <label>Upload PDF Report (optional)</label>
          <input type="file" name="labReport" accept=".pdf">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" onclick="closeUpload()">Cancel</button>
        <button type="submit" class="btn-submit"><i class="bi bi-check-lg"></i> Submit Results</button>
      </div>
    </form>
  </div>
</div>

<!-- VIEW RESULTS MODAL -->
<div class="modal-overlay" id="viewModal">
  <div class="modal">
    <div class="modal-header">
      <h3><i class="bi bi-clipboard-data"></i> Lab Results</h3>
      <button class="modal-close" onclick="closeView()">✕</button>
    </div>
    <div class="modal-body">
      <div class="m-info-box">
        <div><strong id="view-patient"></strong></div>
        <div style="margin-top:4px;">Tests: <strong id="view-tests"></strong></div>
        <div style="margin-top:2px;">Doctor: <strong id="view-doctor"></strong></div>
      </div>
      <div class="m-group">
        <label>Results</label>
        <div class="result-block" id="view-results"></div>
      </div>
      <div id="view-pdf-row" style="display:none;">
        <a id="view-pdf-link" href="#" target="_blank" class="btn-action btn-view">
          <i class="bi bi-file-pdf"></i> View PDF Report
        </a>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn-cancel" onclick="closeView()">Close</button>
    </div>
  </div>
</div>

<script>
// UPLOAD MODAL
function openUpload(visitId, patient, tests, doctor) {
  document.getElementById('upload-visit-id').value = visitId;
  document.getElementById('upload-patient').textContent = patient;
  document.getElementById('upload-tests').textContent = tests;
  document.getElementById('upload-doctor').textContent = doctor;
  document.getElementById('uploadModal').classList.add('open');
}
function closeUpload() {
  document.getElementById('uploadModal').classList.remove('open');
}

// VIEW MODAL
function openView(patient, tests, doctor, results, pdfPath) {
  document.getElementById('view-patient').textContent = patient;
  document.getElementById('view-tests').textContent = tests;
  document.getElementById('view-doctor').textContent = doctor;
  document.getElementById('view-results').textContent = results;

  const pdfRow = document.getElementById('view-pdf-row');
  if (pdfPath) {
    document.getElementById('view-pdf-link').href = '/' + pdfPath;
    pdfRow.style.display = 'block';
  } else {
    pdfRow.style.display = 'none';
  }

  document.getElementById('viewModal').classList.add('open');
}
function closeView() {
  document.getElementById('viewModal').classList.remove('open');
}

// Close on backdrop click
document.getElementById('uploadModal').addEventListener('click', function(e) {
  if (e.target === this) closeUpload();
});
document.getElementById('viewModal').addEventListener('click', function(e) {
  if (e.target === this) closeView();
});
</script>

</body>
</html>