<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Doctor Consultation</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet"/>
<style>
body { background:#f4f6f9; }
.header-bar { background:#1e293b; color:white; }
.card-box { background:#fff; padding:20px; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,0.08); margin-bottom:20px; }
.section-title { font-size:15px; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:5px; color:#444; }
.vital-pill { background:#eef2ff; padding:8px 12px; border-radius:8px; font-size:13px; margin:5px; display:inline-block; }
.history-box { background:#f9fafb; padding:12px; border-radius:8px; margin-top:10px; }

/* EXTERNAL LAB BUTTON */
.btn-external {
  padding: 8px 16px;
  border: 1.5px solid #f59e0b;
  background: transparent;
  color: #92400e;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.btn-external:hover {
  background: #f59e0b;
  color: white;
  border-color: #f59e0b;
}

/* CUSTOM MODAL */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:9999; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal-box { background:white; border-radius:12px; width:100%; max-width:480px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.2); margin:20px; }
.modal-hdr { background:#1e293b; color:white; padding:18px 22px; display:flex; justify-content:space-between; align-items:center; }
.modal-hdr h5 { margin:0; font-size:16px; font-weight:600; }
.modal-hdr button { background:transparent; border:none; color:#94a3b8; font-size:22px; cursor:pointer; line-height:1; }
.modal-hdr button:hover { color:white; }
.modal-bdy { padding:22px; }
.modal-ftr { padding:14px 22px; border-top:1px solid #f1f5f9; display:flex; justify-content:flex-end; gap:10px; }

.ai-card {
  position: sticky;
  top: 20px;

  background: linear-gradient(
    135deg,
    #eff6ff,
    #ffffff
  );

  border-left: 5px solid #2563eb;

  border-radius: 12px;

  padding: 16px;

  margin-bottom: 20px;

  box-shadow: 0 8px 20px rgba(0,0,0,.08);

  animation: slideIn .4s ease;
}

.ai-card h6 {
  color: #2563eb;
  margin-bottom: 8px;
}

.ai-card p {
  margin: 0;
  font-size: 14px;
  line-height: 1.6;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
</head>

<body>

<div class="header-bar text-center py-3">
  <h4><i class="bi bi-clipboard2-pulse me-2"></i>Doctor Consultation</h4>
</div>

<div class="container py-4">

  <!-- PATIENT INFO -->
  <div class="card-box">
    <div class="section-title">Patient Info</div>
    <div class="row">
      <div class="col-md-6">
        <p><strong>Name:</strong> <%= patient.name %></p>
        <p><strong>ID:</strong> <%= patient.patientID %></p>
        <p><strong>Gender:</strong> <%= patient.gender %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Phone:</strong> <%= patient.number %></p>
        <p><strong>Blood Type:</strong> <%= patient.bloodType || "N/A" %></p>
        <p><strong>Allergies:</strong> <%= patient.allergies || "None" %></p>
      </div>
    </div>
  </div>

  <!-- CURRENT VITALS -->
  <div class="card-box">
    <div class="section-title"><i class="bi bi-heart-pulse me-1"></i> Current Vitals</div>
    <% if (visit.vitals) { %>
      <span class="vital-pill">Temp: <%= visit.vitals.temperature %> °C</span>
      <span class="vital-pill">BP: <%= visit.vitals.bloodPressure %></span>
      <span class="vital-pill">HR: <%= visit.vitals.heartRate %> bpm</span>
      <span class="vital-pill">Resp: <%= visit.vitals.respiratoryRate %></span>
      <span class="vital-pill">Weight: <%= visit.vitals.weight %> kg</span>
      <span class="vital-pill">Height: <%= visit.vitals.height %> cm</span>
    <% } else { %>
      <p>No vitals recorded</p>
    <% } %>
  </div>

  <!-- DOCTOR FORM — main consultation form -->
  <div class="card-box">
    <div class="section-title">Consultation</div>

    <form method="POST" action="/visit/<%= visit._id %>/doctor" id="consultForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Chief Complaint</label>
          <textarea name="complaint" class="form-control" rows="2"><%= visit.complaint || "" %></textarea>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Observation</label>
          <textarea name="observation" class="form-control" rows="2"><%= visit.observation || "" %></textarea>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Requested Tests (Lab)</label>
        <textarea name="tests" class="form-control" rows="2" placeholder="e.g. Blood test, MRI, X-ray"><%= visit.tests || "" %></textarea>
      </div>

      <!-- LAB RESULTS — shown when results are back -->
      <% if (visit.labResults || visit.labResult) { %>
      <div class="alert alert-success mt-3">
        <h6 class="mb-3"><i class="bi bi-check-circle-fill me-2"></i>Lab Results Available</h6>
        <% if (visit.labResults) { %>
          <p style="white-space:pre-wrap;"><%= visit.labResults %></p>
        <% } %>
        <% if (visit.labResult) { %>
          <a href="/<%= visit.labResult %>" target="_blank" class="btn btn-sm btn-outline-success mt-2">
            <i class="bi bi-file-earmark-pdf me-1"></i> View Lab PDF
          </a>
        <% } %>
      </div>
      <% } %>

      <div class="mb-3">
        <label class="form-label">Diagnosis</label>
        <textarea name="diagnosis" class="form-control" rows="2"><%= visit.diagnosis || "" %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Prescription</label>
        <textarea name="prescription" class="form-control" rows="2"><%= visit.prescription || "" %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Additional Notes</label>
        <textarea name="notes" class="form-control" rows="2"><%= visit.notes || "" %></textarea>
      </div>

      <!-- ACTION BUTTONS -->
      <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-2">

        <div class="d-flex gap-2 align-items-center flex-wrap">

          <% if (visit.status !== "lab-complete") { %>

            <!-- INTERNAL LAB -->
            <button type="submit" name="status" value="lab" class="btn btn-warning px-4">
              <i class="bi bi-beaker me-1"></i> Send to Lab
            </button>

            <!-- EXTERNAL LAB — styled button, posts to separate route -->
            <button type="button" class="btn-external" id="externalLabBtn">
              <i class="bi bi-box-arrow-up-right"></i> External Lab
            </button>

          <% } %>

        </div>

        <div class="d-flex gap-2 align-items-center flex-wrap">

          <button type="button" class="btn btn-primary px-4" id="openAdmitBtn">
            <i class="bi bi-hospital me-1"></i> Admit Patient
          </button>

          <button type="submit" name="status" value="completed" class="btn btn-success px-4">
            <i class="bi bi-check-circle me-1"></i> Complete Visit
          </button>

        </div>

      </div>
    </form>
    <!-- CONSULTATION FORM ENDS HERE -->

  </div>
<!-- CLINICAL INSIGHTS -->

<% if (summary) { %>

<div class="ai-card">

  <h6>
    <i class="bi bi-cpu-fill me-2"></i>
    Clinical Insights
  </h6>

  <p>
    <%= summary %>
  </p>

</div>

<% } %>

<!-- PREVIOUS VISITS -->

<div class="card-box">
  <div class="section-title">
    Previous Visits
  </div>
  <!-- PREVIOUS VISITS -->
  <div class="card-box">
    <div class="section-title">Previous Visits</div>
    <% if (visits.length <= 1) { %>
      <p style="color:#94a3b8;font-size:14px;">No previous visits</p>
    <% } %>
    <% visits.slice(1).forEach(v => { %>
    <details class="mb-3">
      <summary style="cursor:pointer;"><strong><%= new Date(v.createdAt).toLocaleString() %></strong></summary>
      <div class="history-box">
        <% if (v.vitals) { %>
          <span class="vital-pill">Temp: <%= v.vitals.temperature %></span>
          <span class="vital-pill">BP: <%= v.vitals.bloodPressure %></span>
          <span class="vital-pill">HR: <%= v.vitals.heartRate %></span>
          <span class="vital-pill">Weight: <%= v.vitals.weight %> kg</span>
        <% } %>
        <div class="mt-2">
          <p><strong>Complaint:</strong> <%= v.complaint || "—" %></p>
          <p><strong>Diagnosis:</strong> <%= v.diagnosis || "—" %></p>
          <p><strong>Prescription:</strong> <%= v.prescription || "—" %></p>
          <p><strong>Tests:</strong> <%= v.tests || "—" %></p>
          <p><strong>Notes:</strong> <%= v.notes || "—" %></p>
          <% if (v.labResult) { %>
            <a href="/<%= v.labResult %>" target="_blank" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-file-earmark-pdf"></i> View Result
            </a>
          <% } %>
        </div>
      </div>
    </details>
    <% }) %>
  </div>

</div>
<!-- CONTAINER ENDS -->


<!-- ADMIT MODAL — outside all forms -->
<div class="modal-overlay" id="admitOverlay">
  <div class="modal-box">
    <div class="modal-hdr">
      <h5><i class="bi bi-hospital me-2"></i>Admit Patient</h5>
      <button id="closeAdmitBtn">✕</button>
    </div>
    <form method="POST" action="/admit/<%= patient._id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="visitId" value="<%= visit._id %>">
      <div class="modal-bdy">
        <div class="mb-3">
          <label class="form-label fw-semibold">Reason for Admission</label>
          <textarea name="admissionReason" class="form-control" rows="2" required
            placeholder="e.g. Severe hypertension requiring monitoring"></textarea>
        </div>
        <div class="row g-3">
          <div class="col-6">
            <label class="form-label fw-semibold">Ward</label>
            <input type="text" name="ward" class="form-control" required placeholder="e.g. Emergency">
          </div>
          <div class="col-6">
            <label class="form-label fw-semibold">Bed</label>
            <input type="text" name="bed" class="form-control" placeholder="e.g. Bed 4">
          </div>
        </div>
        <div class="mt-3">
          <label class="form-label fw-semibold">Initial Status</label>
          <select name="status" class="form-select">
            <option value="observation">Observation</option>
            <option value="stable">Stable</option>
            <option value="critical">Critical</option>
            <option value="chronic">Chronic</option>
          </select>
        </div>
      </div>
      <div class="modal-ftr">
        <button type="button" class="btn btn-light" id="cancelAdmitBtn">Cancel</button>
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-hospital me-1"></i> Confirm Admission
        </button>
      </div>
    </form>
  </div>
</div>


<!-- EXTERNAL LAB FORM — hidden, outside main form, submitted by JS -->
<form method="POST" action="/visit/<%= visit._id %>/external-lab" id="externalLabForm" style="display:none;">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <input type="hidden" name="complaint">
  <input type="hidden" name="observation">
  <input type="hidden" name="tests">
  <input type="hidden" name="diagnosis">
  <input type="hidden" name="prescription">
  <input type="hidden" name="notes">
</form>


<script>
// ADMIT MODAL
var admitOverlay = document.getElementById('admitOverlay');
document.getElementById('openAdmitBtn').addEventListener('click', function() {
  admitOverlay.classList.add('open');
});
document.getElementById('closeAdmitBtn').addEventListener('click', function() {
  admitOverlay.classList.remove('open');
});
document.getElementById('cancelAdmitBtn').addEventListener('click', function() {
  admitOverlay.classList.remove('open');
});
admitOverlay.addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

// EXTERNAL LAB — submits the hidden form directly
var externalLabBtn = document.getElementById('externalLabBtn');

if (externalLabBtn) {

  externalLabBtn.addEventListener('click', function() {

    // copy ALL consultation fields
    document.querySelector('#externalLabForm [name="complaint"]').value =
      document.querySelector('[name="complaint"]').value;

    document.querySelector('#externalLabForm [name="observation"]').value =
      document.querySelector('[name="observation"]').value;

    document.querySelector('#externalLabForm [name="tests"]').value =
      document.querySelector('[name="tests"]').value;

    document.querySelector('#externalLabForm [name="diagnosis"]').value =
      document.querySelector('[name="diagnosis"]').value;

    document.querySelector('#externalLabForm [name="prescription"]').value =
      document.querySelector('[name="prescription"]').value;

    document.querySelector('#externalLabForm [name="notes"]').value =
      document.querySelector('[name="notes"]').value;

    document.getElementById('externalLabForm').submit();
  });

}
</script>

</body>
</html>